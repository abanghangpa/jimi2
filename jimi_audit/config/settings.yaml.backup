# ═══════════════════════════════════════════════════════════════
# JIMI Framework — Central Configuration
# ═══════════════════════════════════════════════════════════════
# Override any parameter here. Unset keys fall back to defaults.
# Switch between "modes" by passing --config v615.yaml etc.

# ─── MACRO CACHE ─────────────────────────────────────────────
# TTL in days for macro indicator cache (default: 7).
# Macro data (PMI, CPI, GDP, rate decisions) releases monthly/quarterly.
# Set to 0 to always fetch fresh (old behavior: 24h TTL).
MACRO_CACHE_TTL_DAYS: 7

# ─── GATE THRESHOLDS ─────────────────────────────────────────
ICS_THRESHOLD_NORMAL: 0.65     # raised from 0.62 — 0.65+ bucket has 76% WR
ICS_THRESHOLD_CAUTION: 0.65
ICS_FLOOR: 0.48       # keep original — 0.48-0.55 bucket has positive edge

# ─── M4b: INTRABAR CVD (LucF-style) ─────────────────────────
M4B_INTRABAR_ENABLED: true
M4B_INTRABAR_HOURS: 72
ICS_FLOOR_M4_FALSE: 0.48
ICS_CEILING: 0.75       # relaxed — 0.7+ bucket was strong in 10d attribution

# Pre-check gate (M1-M4+M10 only, before M5/M7/M8/M11-M14)
# Separate from final ICS threshold — pre-check has fewer modules
ICS_PRECHECK_FLOOR: 0.45
ICS_PRECHECK_THRESHOLD: 0.45

# ─── MODULE WEIGHTS (ICS) ────────────────────────────────────
# Rebalance based on 10-day attribution (2026-04-24 → 2026-05-03) + OOS validation:
#   M4 (CVD): STRONG — +0.22 delta, 100% WR at ≥0.7. Moderate boost.
#   M10 (Macro): stabilizer, restore to 0.20 for regime gating.
#   M11 (MTF Mom): INVERTED — high scores predict losses → zero.
#   M5 (Liquidation): no differentiating power → zero.
#   M1 (MACD): decent at 0.6-0.7 → small boost.
#   M3 (VWAP): stable predictor → boost to 0.20.
#   M6 (Derivatives): reduce to 0.08.
#   M12 (OrderBook): live-only, no backtest signal → zero.
#   Weights sum to 1.00 (base=0.65 + extras=0.35).
#   ICS threshold raised to 0.62 (weights lower = easier to cross).
M1_WEIGHT: 0.00       # INVERTED 2026: Δ=-0.047, winners score LOWER → zero
M2_WEIGHT: 0.00       # veto-only (also inverted: Δ=-0.023)
M3_WEIGHT: 0.25       # STRONG predictor 2026: Δ=+0.060, boost (was 0.20)
M4_WEIGHT: 0.20       # STRONG predictor 2026: Δ=+0.106, boost (was 0.15)
M5_WEIGHT: 0.00       # no signal power 2026: Δ=+0.003 → zero
M10_WEIGHT: 0.15      # moderate, neutral predictor 2026: Δ=+0.007 (was 0.20)
M11_WEIGHT: 0.00      # INVERTED — high scores predict losses → zero
M13_WEIGHT: 0.10      # structural bias, keep
M14_WEIGHT: 0.08      # sweep-retest, keep
M8_WEIGHT: 0.10       # funding rate, keep
M6_WEIGHT: 0.08       # derivatives, keep
M20_WEIGHT: 0.10      # failed breakout detector
TAKER_ENABLED: true
TAKER_WEIGHT: 0.08    # taker flow momentum + regime
TAKER_DEVIATION_THRESHOLD: 0.02   # min deviation from 0.50 to score
TAKER_MOMENTUM_BONUS: 0.20       # max score from momentum
TAKER_12H_AGREE_BONUS: 0.15      # bonus when 12h confirms
TAKER_DIVERGENCE_PENALTY: 0.50   # multiplier when 12h disagrees

# ─── V6.12 IMPROVEMENTS ─────────────────────────────────────
BIAS_GATE_ENABLED: true
BIAS_GATE_LONG_ICS: 0.50
TREND_FILTER_ENABLED: true
TREND_BLOCK_COUNTER_TREND: false
TREND_STRONG_ONLY: false
TREND_MIN_SCORE: 0.05
TREND_MIN_SCORE_NEUTRAL: 0.03   # relaxed in NEUTRAL/COMPRESSING regime
MONTHLY_DD_CIRCUIT: 0.05

# ─── V6.13 SEASONAL ─────────────────────────────────────────
SUMMER_MONTHS: [6, 7, 8, 9]
SUMMER_SIZE_MULT: 0.60
SUMMER_ICS_BOOST: 0.03
TP1_CLOSE_BASE: 0.30
TP1_CLOSE_SUMMER: 0.45
TP1_ATR_SUMMER: 0.7
MAX_CONSEC_LOSS_SUMMER: 2
CONSEC_LOSS_PAUSE_SUMMER: 12
PHASE0_SUMMER_BLOCK: 0.60

SHOULDER_MONTHS: [3, 10]
SHOULDER_SIZE_MULT: 0.50
SHOULDER_SL_ATR: 1.4
SHOULDER_SL_HARD_MAX: 0.016
SHOULDER_TP1_ATR: 0.8
SHOULDER_TP1_CLOSE: 0.45
SHOULDER_ICS_BOOST: 0.02
SHOULDER_MAX_TRADES_DAY: 3

# ─── MODULE GATES ────────────────────────────────────────────
M2_VETO_ENABLED: true
M2_VETO_THRESHOLD: 0.40
M5_FAIL_ICS_BOOST: 0.00
M5_FAIL_HARD_THRESHOLD: 0.25
M7_HARD_GATE: false
M7_GATE_THRESHOLD: 0.30
M7_GATE_STRONG_THRESHOLD: 0.60
M7_GATE_STRONG_BOOST: 0.04
SESSION_ASIAN_BLOCK: false
POST_CRASH_COOLDOWN: true
POST_CRASH_THRESHOLD: 0.10
POST_CRASH_BARS: 48
CASCADE_MULTIPLIER: 1.12
CASCADE_PENALTY: 0.85
DIR_VETO_ENABLED: true

# ─── TECHNICAL INDICATORS ────────────────────────────────────
MACD_FAST: 12
MACD_SLOW: 26
MACD_SIGNAL: 9
EMA_FAST: 21
EMA_SLOW: 55
RSI_PERIOD: 14
ATR_PERIOD: 14

# ─── M3: VWAP ENTRY ZONE ────────────────────────────────────
VWAP_LOOKBACK: 96
VWAP_ZONE_PCT: 0.012
VOL_THRESHOLD: 0.25
TAKER_LONG: 0.52
TAKER_SHORT: 0.48
TAKER_FILLNA: 0.50
SIGNAL_EXPIRY: 3

# ─── M4: CVD ────────────────────────────────────────────────
CVD_LOOKBACK: 36
CVD_DIVERGENCE_WINDOW: 12
M4_ZL_LOOKBACK: 18
M4_ZL_MOMENTUM_BARS: 13      # v7: was 8, raised to filter bid-ask churn (13 bars = 3.25hr)
M4_DIV_WEIGHT: 0.40
M4_ZL_WEIGHT: 0.60
# v7: Sigmoid gating — weak M4 signals get near-zero weight
M4_SIGMOID_CENTER: 0.65      # inflection point where gate = 0.5
M4_SIGMOID_STEEPNESS: 12     # transition sharpness (higher = sharper cliff)
# v7: ATR scaling — dampen M4 in low-vol sessions (spread noise dominates)
M4_ATR_SCALING_ENABLED: true

# ─── M5: LIQUIDATION MAGNET ─────────────────────────────────
M5_VP_LOOKBACK: 672
M5_VP_BINS: 50
M5_MIN_SCORE: 0.25
M5_SWEET_SPOT_LOW: 0.30
M5_SWEET_SPOT_HIGH: 0.50
M5_SWEET_SPOT_BOOST: 0.04

# ─── STOP LOSS ───────────────────────────────────────────────
SL_ATR_STD: 1.3
SL_ATR_STD_SUMMER: 1.6
SL_ATR_TRANSITION: 1.0
TP1_ATR_TRANSITION: 1.2
TRANSITION_SIZE_MULT: 0.50
TRANSITION_SCORE_RANGE: 0.20
SL_HARD_MAX_PCT: 0.018
SL_HARD_MAX_SUMMER: 0.018
SL_BREAKEVEN_AFTER_TP1: true
EARLY_EXIT_BARS: 24           # tightened: was 16, 16 early exits had 0% WR (-9.71% drag)
EARLY_EXIT_MIN_LOSS: 0.005    # tightened: was 0.003, require bigger loss before cutting
EARLY_EXIT_BARS_SUMMER: 12
EARLY_EXIT_MIN_LOSS_SUMMER: 0.002

# ─── TAKE PROFIT LADDER ─────────────────────────────────────
TP1_ATR: 1.5
TP2_ATR: 2.0
TP3_ATR: 3.5
TP1_CLOSE: 0.30
TP2_CLOSE: 0.30

# ─── POSITION SIZING ────────────────────────────────────────
SIZE_STD: 5.0
SIZE_LONG: 5.0
SIZE_M2_NEUTRAL: 2.5
SIZE_CAUTION: 3.5

# ─── ENTRY FILTERS ──────────────────────────────────────────
BAR_MOVE_ATR: 0.5
ATR_FILTER_MAX: 0.035
MIN_ENTRY_DIST_PCT: 0.002
MIN_RR_RATIO: 0.50             # reject signals where TP1 R:R is below this (e.g. 0.50 = TP1 must be ≥50% of SL distance)

# ─── RISK MANAGEMENT ────────────────────────────────────────
MAX_TRADES_DAY: 5
MAX_TRADES_DAY_SUMMER: 3
MAX_DAILY_LOSS: 0.05
MAX_DAILY_LOSS_SUMMER: 0.03
COOLDOWN_BARS: 2
COOLDOWN_BARS_SUMMER: 4
SHOULDER_COOLDOWN_BARS: 3
ROLLING_WR_WINDOW: 20
ROLLING_WR_MIN: 0.15
MAX_CONSEC_LOSS: 3
CONSEC_LOSS_PAUSE_BARS: 8

# ─── LONG FILTER ────────────────────────────────────────────
LONG_MIN_ICS: 0.50

# ─── PHASE0 MIN BLOCK (forensic P1) ────────────────────────
# Phase0 < 0.2 is the "death zone" — 33% WR in 2024, 49% in 2023.
# Block entries when Phase0 is too low (market is directionless).
PHASE0_MIN_BLOCK: 0.20        # raised from 0.10 — death zone <0.15 has 50% WR

# ─── M5 REGIME GATE (forensic P1) ──────────────────────────
# M5 (Liquidation Magnet) is inverted in bull markets, predictive in bear.
# Gate M5 scoring: only give full M5 credit in trending/bear regimes.
# In CHOP_MILD/bull ranges, M5 score is capped to 0.5 (neutral).
M5_REGIME_GATE_ENABLED: true

# ─── M6: DERIVATIVES ────────────────────────────────────────
M6_WEIGHT: 0.08
M3_WEIGHT_DERIV: 0.25
M4_WEIGHT_DERIV: 0.20
DERIV_ENABLED: true

# ─── M7: MARKET REGIME ──────────────────────────────────────
M7_ENABLED: true
M7_WEIGHT: 0.00
M7_SIZE_REDUCTION: 0.70
M7_SIZE_MILD: 0.85

# ─── M8: FUNDING RATE ───────────────────────────────────────
M8_ENABLED: true
M8_WEIGHT: 0.10
M8_HIGH_FUNDING: 0.05
M8_LOW_FUNDING: -0.05
M8_FLIP_BONUS: 0.15

# ─── M9: VOLATILITY REGIME ──────────────────────────────────
M9_ENABLED: true
M9_WEIGHT: 0.00
M9_BLOCK_REGIMES: ["CRISIS", "CHOP_HARD", "NEUTRAL_CHOP"]
M9_SIZE_CHOP_MILD: 0.55
M9_SIZE_COMPRESSING: 0.85
# Chop regime: tap nearest liquidity, exit, no continuation
CHOP_TP1_ATR: 0.6          # tight TP1 — nearest liquidity pool
CHOP_TP1_CLOSE: 0.90       # exit 90% at TP1
CHOP_SL_ATR: 0.5           # very tight SL — small loss if wrong
CHOP_SL_HARD_MAX: 0.008    # hard SL cap in chop (0.8%)
# Regime detection thresholds (v2)
M9_WHIPSAW_THRESHOLD: 0.45
M9_RETRACE_THRESHOLD: 0.50
M9_TRENDING_MIN_DIR: 0.45
M9_TRENDING_MIN_VOLUME: 0.50
M9_TRENDING_MAX_WHIPSAW: 0.35
M9_TRENDING_MAX_RETRACE: 0.45
M9_TRENDING_MIN_COHERENCE: 0.50

# Regime classification thresholds
M9_CRISIS_ATR_THRESHOLD: 0.85
M9_CRISIS_BB_THRESHOLD: 0.90
M9_CHOP_HARD_CHOP_SCORE: 0.72
M9_CHOP_HARD_WHIPSAW: 0.70
M9_CHOP_HARD_RETRACE: 0.80
M9_CHOP_MILD_CHOP_SCORE: 0.50
M9_CHOP_MILD_TREND_CEILING: 0.35
M9_TRENDING_TREND_SCORE: 0.40
M9_TRENDING_MAX_WHIPSAW_SCORE: 0.65
M9_TRENDING_MAX_RETRACE_SCORE: 0.80
M9_COMPRESSING_BB: 0.30
M9_COMPRESSING_ATR: 0.40
M9_COMPRESSING_RANGE: 0.60
M9_HYSTERESIS_CONFIRM_BARS: 2
M9_TRENDING_CONFIRM_BARS: 3
M9_COMPRESSING_CONFIRM_BARS: 3
M9_CRISIS_COOLDOWN: 8
M9_TRENDING_COOLDOWN: 4
M9_COMPRESSING_COOLDOWN: 6
M9_CHOP_HARD_COOLDOWN: 6
M9_CHOP_MILD_COOLDOWN: 4

# CHOP_MILD directional split + time-based exit
M9_CHOP_SPLIT_ENABLED: true
M9_CHOP_MAX_BARS: 96
M9_CHOP_EXIT_COOLDOWN: 12

# NEUTRAL sub-classification: split NEUTRAL into TRENDING vs CHOP
M9_NEUTRAL_DIR_THRESHOLD: 0.40
M9_NEUTRAL_VOL_THRESHOLD: 1.05

# ─── SURVIVAL FILTER ────────────────────────────────────────
# Momentum gate: reject entries when recent bars show no directional push
SURVIVAL_FILTER_ENABLED: true
SURVIVAL_LOOKBACK: 12           # bars to check (12 = 3h on 15m)
SURVIVAL_MIN_MOVE: 0.002        # min net move in trade direction (0.2%)
SURVIVAL_MIN_CONSISTENCY: 0.35  # min fraction of bars closing in trade direction
SURVIVAL_VOL_RATIO: 0.30        # min recent ATR / 1H ATR ratio

# ─── TIME-STOP (ADAPTIVE) ───────────────────────────────────
# Exit trade if TP1 not hit within N bars (0 = disabled)
# ADAPTIVE: time stop scales with TP1 distance.
#   bars = max(BASE, BASE + tp1_pct * PER_PCT), capped at MAX
# Wider TP targets get more time; tight TPs exit faster.
TIME_STOP_BARS: 20            # legacy fallback (overridden by BASE below)
TIME_STOP_BASE_BARS: 20       # minimum time stop bars
TIME_STOP_PER_PCT: 25         # extra bars per 1% of TP1 distance
TIME_STOP_MAX_BARS: 60        # hard cap

# ─── M10: CROSS-ASSET MACRO ─────────────────────────────────
M10_ENABLED: true
M10_FETCH_ON_BACKTEST: true

# ─── M11: MULTI-TF MOMENTUM ─────────────────────────────────
M11_ENABLED: true
M11_RSI_PERIOD_15M: 14
M11_RSI_PERIOD_1H: 14
M11_REQUIRE_AGREEMENT: true

# ─── M12: ORDER BOOK ────────────────────────────────────────
M12_ENABLED: true
M12_WEIGHT: 0.00
M12_LIVE_ONLY: true

# ─── ADAPTIVE DIRECTION BIAS ────────────────────────────────
ADAPTIVE_DIR_ENABLED: true
ADAPTIVE_DIR_MIN_BIAS: 0.05
ADAPTIVE_DIR_BLOCK_THRESHOLD: 0.40

# ─── DATA FRESHNESS ─────────────────────────────────────────
DATA_FRESHNESS_ENABLED: true
DATA_FRESHNESS_MAX_AGE_MIN: 20
DATA_FRESHNESS_CHECK_INTERVAL: 5

# ─── VETO SYSTEM ────────────────────────────────────────────
VETO_ENABLED: true
VETO_CRISIS_HARD: true
VETO_CHOP_HARD: false
VETO_STALE_DATA_HARD: true
VETO_MONTHLY_DD_HARD: true
VETO_DIR_CONFLICT_HARD: true

# ─── ADAPTIVE WEIGHTS ───────────────────────────────────────
ADAPTIVE_WEIGHTS_ENABLED: true
ADAPTIVE_DECAY: 0.97
ADAPTIVE_MIN_MULT: 0.8
ADAPTIVE_MAX_MULT: 1.2
ADAPTIVE_WARMUP_TRADES: 15

# ─── SESSION AWARENESS ──────────────────────────────────────
SESSION_AWARENESS_ENABLED: true
SESSION_ASIAN_MULT: 1.10
SESSION_EU_MULT: 1.0
SESSION_US_MULT: 0.85         # reduced from 1.05 — US session 50% WR, -0.32% PnL in 2026
SESSION_LATE_US_MULT: 0.90
SESSION_US_OPEN_BOOST: 0.85

# ─── MULTI-TF ENTRY CONFIRMATION ────────────────────────────
MTF_CONFIRM_ENABLED: true
MTF_1H_CANDLE_CHECK: true
MTF_4H_EMA_CHECK: false

# ─── M13: STRUCTURAL BIAS ─────────────────────────────────────
M13_ENABLED: true
M13_WEIGHT: 0.10
# M13 defers to M9 during chop (anti-predictive when agreeing)
M13_DEFER_IN_CHOP: true

# ─── COHERENCE CHECK ────────────────────────────────────────
COHERENCE_CHECK_ENABLED: true
COHERENCE_MAX_CONFLICTS: 3
COHERENCE_M4_PENALTY: 0.01    # v8: was 0.02 — M4 at 6% weight + sigmoid-gated, penalty was 33% of max contribution
COHERENCE_M5_PENALTY: 0.03
COHERENCE_M13_PENALTY: 0.03
COHERENCE_M7_PENALTY: 0.02
COHERENCE_MAX_PENALTY: 0.10

# ─── LIQUIDITY-AWARE TP ─────────────────────────────────────
LIQUIDITY_TP_ENABLED: true
LIQUIDITY_FRICTION_THRESHOLD: 0.60
LIQUIDITY_VOID_THRESHOLD: 0.20
LIQUIDITY_TP1_ADJUST_UP: 0.08
LIQUIDITY_TP1_ADJUST_DOWN: 0.05
STOP_RISK_THRESHOLD: 0.55
STOP_RISK_TIGHTEN: true
STOP_RISK_TIGHTEN_FACTOR: 0.85

# ─── M14: SWEEP-RETEST-RECLAIM ──────────────────────────────
M14_ENABLED: true
M14_WEIGHT: 0.08
M14_SWEEP_LOOKBACK: 20
M14_SWEEP_DEPTH_MIN: 0.001
M14_SWEEP_DEPTH_MAX: 0.020
M14_RECLAIM_BARS: 3
M14_RECLAIM_WICK_RATIO: 0.40
M14_VOL_CONFIRM_MULT: 1.2
M14_STRONG_SCORE: 0.85
M14_WEAK_SCORE: 0.55
M14_SLICE_PENALTY: 0.30
M14_NO_SWEEP_SCORE: 0.50
WICK_SLICE_BLOCK: false

# ─── M17: RESISTANCE QUALITY ─────────────────────────────────
M17_ENABLED: true
M17_WEIGHT: 0.05
M17_ZONE_LOOKBACK: 960           # 10 days of 15m bars
M17_ZONE_WIDTH_PCT: 0.5          # zone width as % of price (±0.5%)
M17_ZONE_THIN_THRESHOLD: 0.5     # volume ratio below this = thin zone
M17_ZONE_THICK_THRESHOLD: 1.5    # volume ratio above this = thick zone
M17_REJECT_MIN_TOUCHES: 3        # minimum touches to analyze
M17_REJECT_VOL_STRONG: 2.5       # vol ratio = active defender
M17_REJECT_VOL_WEAK: 1.2         # vol ratio = passive defender
M17_REJECT_WICK_STRONG: 5.0      # avg wick above zone ($) = strong defense
M17_DEFENDER_TRAPPED_Z: -2.0     # L/S z-score = defender trapped (shorts)
M17_DEFENDER_TRAPPED_Z_LONG: 2.0 # L/S z-score = defender trapped (longs)
M17_DEFENDER_LEAVING_OI_ROC: -0.5 # OI dropping = defender exiting
M17_DEFENDER_ADDING_OI_ROC: 1.0  # OI rising = defender building
M17_BREAKOUT_VOL_MIN: 1.2        # min volume surge for breakout attempt
M17_BREAKOUT_MOMENTUM_MIN: 0.3   # min % move toward zone
M17_W_ZONE: 0.25                 # weight: zone volume density
M17_W_REJECT: 0.30               # weight: rejection pattern
M17_W_DEFENDER: 0.25             # weight: defender behavior
M17_W_READINESS: 0.20            # weight: breakout readiness

# ─── M1 ENHANCEMENT ─────────────────────────────────────────
M1_RSI_ENABLED: true
M1_MOMENTUM_ENABLED: true
M1_RSI_PERIOD: 14
M1_RSI_OVERBOUGHT: 70
M1_RSI_OVERSOLD: 30
M1_MOMENTUM_LOOKBACK: 6

# ─── M1 MACD DIVERGENCE ─────────────────────────────────────
# Swing-based MACD histogram divergence on 1H, alongside RSI divergence.
# Fires when price makes a new extreme but MACD histogram doesn't confirm.
M1_MACD_DIV_ENABLED: true
M1_MACD_DIV_LOOKBACK: 40       # bars to scan for divergence swings

# M1 v2 blend weights (RSI div + MACD div + crossover + momentum)
M1_W_RSI_DIV: 0.25
M1_W_MACD_DIV: 0.20
M1_W_CROSSOVER: 0.35
M1_W_MOMENTUM: 0.20
M1_DIV_AGREE_BOOST: 0.03       # bonus when both RSI + MACD div fire same side

# ─── LIQUIDITY-AWARE SL/TP ─────────────────────────────────
LIQUIDITY_LEVELS_ENABLED: true     # use liquidity data for SL/TP placement
SL_VOID_BUFFER_PCT: 0.003          # buffer around levels = "clustered"
SL_VOID_MIN_DIST_PCT: 0.002        # min SL distance as % of price
SL_VOID_MAX_DIST_PCT: 0.025        # max SL distance (2.5% cap)
TP1_USE_MAGNET: true               # target nearest unswept magnet for TP1
TP1_MAGNET_MIN_DIST_PCT: 0.002     # min distance to magnet

# ─── M14 SWEEP GATE ────────────────────────────────────────
M14_ENTRY_GATE: false              # require M14 sweep before signaling
SWEEP_PROXIMITY_PCT: 0.001         # 0.1% — near-miss tolerance for swept detection (price within X% of level counts as tested)

# ─── M23: PPI SESSION ANALYSIS ──────────────────────────────
M23_ENABLED: true

# ─── MACRO EVENT PRE-FILTER ─────────────────────────────────
# Backtested Phase0 + 30d trend + cascade window filter
# Phase0 < 0.15 = DEATH_ZONE (43% WR) → block entries
# Phase0 0.15-0.30 = LOW → reduced size
# Active HIGHEST impact cascade → block or reduce size
MACRO_EVENT_FILTER_ENABLED: true
PHASE0_CAUTION: 0.30
MACRO_CASCADE_SIZE_MULT: 0.70
MACRO_LOOKBACK_HOURS: 4
MACRO_LOOKAHEAD_HOURS: 2
M23_CLAIMS_ENABLED: true          # Include jobless claims in macro analysis
M23_CLAIMS_WEIGHT: 0.08           # ICS weight for claims signal (when standalone release)
M23_COMBO_ENABLED: true           # Enable CPI×PPI×Claims combo matrix

# ─── CASCADE META-AGGREGATOR ───────────────────────────────
# Generic cascade engine: scores regional macro release chains
# as unified signals. Each cascade has a weight in the global score.
CASCADE_ENABLED: true                  # Master switch for all cascades
CASCADE_US_INFLATION_ENABLED: true     # CPI→PPI→PCE→FOMC→Presser→Minutes
CASCADE_US_LABOR_ENABLED: true         # ADP→JOLTS→NFP→Unemployment→Claims
CASCADE_US_ACTIVITY_ENABLED: true      # ISM Mfg→ISM Svc→Retail→Durables→GDP
CASCADE_CHINA_MACRO_ENABLED: true      # GDP→PMI→Caixin→Activity→CPI/PPI→PBOC
M_CHINA_ACTIVITY_ENABLED: true          # China monthly activity data (IP, Retail, FAI, Unemp, House)
CASCADE_EU_MACRO_ENABLED: true         # GDP→PMI→DE CPI→EZ CPI→IFO→ECB
CASCADE_UK_MACRO_ENABLED: true         # GDP→CPI→Wages→BoE
CASCADE_JAPAN_MACRO_ENABLED: true      # GDP→CPI→BoJ (carry trade)
CASCADE_AU_MACRO_ENABLED: true         # CPI→RBA

# ─── POWER OF 3 PHASE DETECTOR ─────────────────────────────
P3_MIN_KEY_LEVEL_DIST_PCT: 0.005   # min 0.5% distance for actionable key levels
P3_SWEEP_LOOKBACK: 96              # bars to check for completed sweep (96 = 24h on 15m)

# ─── CROSS-ASSET CORRELATION ────────────────────────────────
CROSS_ASSET_ENABLED: true
CROSS_ASSET_BTC_WEIGHT: 0.08
CROSS_ASSET_LOOKBACK: 48

# ─── M18 SQUEEZE DETECTOR v6 (box typology + quality entry) ──
M18_ENABLED: true
M18_WEIGHT: 0.08

# Detection params (wide_A config: 126 entries, relaxed for more signals)
SQUEEZE_RANGE48_MAX: 3.0             # max 48h range % to consider compression (was 1.2)
SQUEEZE_COIL_DELTA_MAX: 0.15         # 2h MACD DIF-DEA delta % for coiling (was 0.05)
SQUEEZE_COIL_BARS_MIN: 3             # min 2h bars in coil (was 6)
SQUEEZE_COMPRESSION_BARS_MIN: 6      # min 15m compression bars (was 12)
SQUEEZE_DRY_BARS_MIN: 2              # min dry bars (was 4)
SQUEEZE_DOJI_BARS_MIN: 4             # min doji bars (was 8)
SQUEEZE_REQUIRE_HIST_FLIP: false     # allow all trigger types (was true)
SQUEEZE_EMA_FILTER: false            # don't pre-filter on EMA (we filter post-entry)

# Entry trigger
SQUEEZE_ENTRY_BUFFER_PCT: 0.001      # 0.1% buffer above/below coil range
SQUEEZE_ENTRY_EXPIRY_BARS: 32        # entry expires after 8h
SQUEEZE_BREAKOUT_VOL_MULT: 1.0       # volume confirmation on breakout bar
SQUEEZE_ENTRY_MODE: BASELINE          # BASELINE (single close) — was TWO_BAR, faster entry on breakout
SQUEEZE_TAKER_LONG: 0.54              # lowered from 0.58 — Apr 26 05:00 taker was 0.564
SQUEEZE_TAKER_SHORT: 0.46             # raised from 0.42 — symmetric
SQUEEZE_COIL_HOURS_MIN: 12           # skip squeezes with coil < 12h

# ── v6: Box typology ──
SQUEEZE_SWING_PERIOD: 3              # bars each side for fractal detection
SQUEEZE_SLOPE_THRESHOLD: 0.0008      # min slope (fraction of price) to count as trending
SQUEEZE_CONVERGENCE_MIN: 0.3         # min convergence ratio
SQUEEZE_MATURITY_WINDOW: 8           # bars to measure compression maturity
SQUEEZE_MATURITY_THRESHOLD: 1.15     # range_current / range_min below this = mature

# ── v6: Breakout bar quality ──
SQUEEZE_BREAKOUT_CLOSE_PCT: 0.75     # close must be in top/bottom 25% of bar range
SQUEEZE_BREAKOUT_BODY_MIN: 0.50      # body must be > 50% of bar range
SQUEEZE_BREAKOUT_WICK_MAX: 0.30      # rejection wick must be < 30% of bar range
SQUEEZE_VOL_EXPANSION_MIN: 1.3       # breakout bar vol / prev bar vol
SQUEEZE_TAKER_ALIGN: true            # require taker ratio to align with direction

# ── v6: Retest entry ──
SQUEEZE_RETEST_ENABLED: true
SQUEEZE_RETEST_BARS: 8               # max bars to wait for retest after breakout
SQUEEZE_RETEST_TOLERANCE: 0.002      # how close price must come to broken level (0.2%)
SQUEEZE_RETEST_HOLD_BARS: 2          # bars price must hold above/below level after retest

# 5-filter confirmation gate (backtested: 84.6% WR on 4h, 13 signals)
# ALL must pass for squeeze to be considered "confirmed"
SQUEEZE_CONFIRM_EMA: false            # disabled: EMA is lagging during squeeze breakout
SQUEEZE_CONFIRM_CVD: true            # require no CVD divergence against direction
SQUEEZE_CONFIRM_RSI: true            # require RSI not extreme against direction
SQUEEZE_CONFIRM_QUALITY: false        # disabled: quality is low during tight compression (that's the signal)
SQUEEZE_CONFIRM_ATR_FLOOR: false     # disabled: ATR is low DURING compression (that's the signal)

# ATR floor filter (backtest: ATR is #1 predictor of $25+ moves)
SQUEEZE_MIN_ATR: 2.0                 # lowered: was 5.0, Apr 25 ATR was $3.09 during compression
SQUEEZE_ATR_FLOOR_PCTILE: 15         # rolling percentile floor
SQUEEZE_ATR_LOOKBACK: 8640           # lookback for percentile (90 days)

# Exit levels
SQUEEZE_TP_ATR_MULT: 2.5
SQUEEZE_SL_ATR_MULT: 1.0
SQUEEZE_TP_MIN_PCT: 0.3
SQUEEZE_TP_MAX_PCT: 2.0

# Override & cooldown
SQUEEZE_OVERRIDE_REGIME: true
SQUEEZE_ICS_BOOST: 0.10
SQUEEZE_SIZE_MULT: 0.80
SQUEEZE_COOLDOWN_BARS: 32            # 8h cooldown

# ─── M20: FAILED BREAKOUT DETECTOR ───────────────────────────
M20_ENABLED: true
M20_WEIGHT: 0.10
M20_BREAKOUT_LOOKBACK: 48
M20_BREAKOUT_LEVEL_ATR_MULT: 0.5
M20_BREAKOUT_MIN_RANGE_PCT: 0.3
M20_WICK_REJECTION_RATIO: 0.40
M20_TAKER_SELL_THRESHOLD: 0.42
M20_TAKER_BUY_THRESHOLD: 0.58
M20_VOL_FADE_THRESHOLD: 0.7
M20_FAILURE_BARS: 8
M20_FAILURE_RETURN_PCT: 0.3
M20_HOLD_BARS: 4
M20_REVERSAL_VOL_MULT: 1.3
M20_REVERSAL_TAKER_FLIP: true
M20_REVERSAL_BODY_MIN: 0.5
M20_STRONG_SCORE: 0.85
M20_MODERATE_SCORE: 0.65
M20_WEAK_BREAKOUT_SCORE: 0.35
M20_HOLDING_SCORE: 0.50
M20_NO_BREAKOUT_SCORE: 0.50
M20_DIRECTION_OVERRIDE_THRESHOLD: 0.65  # lowered: was 0.80, let M20 override direction more easily
M20_DIRECT_SIGNAL_THRESHOLD: 0.85

# ─── M21: WYCKOFF PHASE + PREMIUM/DISCOUNT ──────────────────
M21_ENABLED: true
M21_WEIGHT: 0.00              # Not in ICS — used as gate/filter
M21_RANGE_LOOKBACK: 48        # 4H bars to detect range (48 = 8 days)
M21_SPRING_LOOKBACK: 12       # 15m bars to check for spring/upthrust
M21_DISTRIBUTION_LONG_BLOCK: true   # Block LONG in distribution + premium
M21_ACCUMULATION_SHORT_BLOCK: true  # Block SHORT in accumulation + discount

# ─── KILL ZONE FILTER ────────────────────────────────────────
KILL_ZONE_FILTER_ENABLED: true
KILL_ZONE_LONDON_OPEN_START: 7
KILL_ZONE_LONDON_OPEN_END: 10
KILL_ZONE_NY_OPEN_START: 12.5
KILL_ZONE_NY_OPEN_END: 15.5
KILL_ZONE_LONDON_CLOSE_START: 15
KILL_ZONE_LONDON_CLOSE_END: 17
KILL_ZONE_ASIAN_MULT: 0.6
KILL_ZONE_OFF_MULT: 0.7

# ─── RANGE-AWARE TP/SL ──────────────────────────────────────
RANGE_TP_ENABLED: true
RANGE_SL_ENABLED: true
RANGE_SL_BUFFER_PCT: 0.05     # 5% of range width as SL buffer
RANGE_TP3_EXTENSION: 0.25     # 25% extension beyond range for TP3
RANGE_SL_HARD_MAX_PCT: 0.025  # Hard max SL at 2.5%

# ─── STRUCTURE-AWARE TP ─────────────────────────────────────
# When in a range, target the opposite side instead of nearest pool
STRUCTURE_TP_ENABLED: true
STRUCTURE_TP_MIN_RANGE_PCT: 1.5   # Min range width to use structure TPs
STRUCTURE_TP_MAX_RANGE_PCT: 6.0   # Max range width

# ─── M22: INFLATION REGIME v2 ────────────────────────────────
# 5D macro regime: PPI_dir × CPI × Fed × Labor × Positioning
# Plus: real rates, PPI acceleration, surprise factors.
# v2: Labor is co-equal (in the matrix, not a modifier). CPI is co-equal.
M22_ENABLED: true
M22_WEIGHT: 0.12              # ICS weight — moderate, macro backdrop modifier
M22_VETO_THRESHOLD: 0.20      # hard veto when score_raw < this (for LONG)
M22_FAIL_THRESHOLD: 0.35      # FAIL when score < this
M22_LS_CROWDED_THRESHOLD: 2.0 # L/S ratio above this = CROWDED positioning

# Position sizing by severity
M22_SIZE_CRITICAL: 0.30       # CRITICAL severity → 30% size
M22_SIZE_HIGH: 0.50           # HIGH severity → 50% size
M22_SIZE_MEDIUM: 0.75         # MEDIUM severity → 75% size

# ── LIVE DATA (update monthly after BLS releases) ──
# PPI: https://www.bls.gov/ppi/  (released mid-month)
# CPI: https://www.bls.gov/cpi/  (released mid-month)
# Fed: https://www.federalreserve.gov/  (8x/year, FOMC)
# NOTE: These are FALLBACK values. FRED live data is primary (auto-fetched).
#       Only update these when FRED is down or as a sanity check.
M22_PPI_YOY: 6.3              # Apr 2026 PPI YoY (FRED WPSFD49207, 2026-04)
M22_PPI_PREV_YOY: 4.3         # Mar 2026 PPI YoY (for direction calc)
M22_PPI_PREV_PREV_YOY: 1.6    # Feb 2026 PPI YoY (for acceleration calc)
M22_PPI_MOM: 0.5              # Apr 2026 PPI MoM
M22_CPI_YOY: 3.8              # Apr 2026 CPI YoY (FRED CPIAUCSL, 2026-04)
M22_CPI_PREV_YOY: 3.3         # Mar 2026 CPI YoY (for CPI direction)
M22_CPI_EXPECTED: 3.6         # CPI consensus expectation (manual — not on FRED)
M22_FED_STANCE: "HOLDING"     # Auto-inferred from FRED FEDFUNDS trajectory
M22_FED_FUNDS_RATE: 3.60      # FRED FEDFUNDS (2026-04)
M22_PPI_EXPECTED: 4.0         # PPI consensus expectation (manual — not on FRED)

